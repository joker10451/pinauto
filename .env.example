# ─── Telegram ─────────────────────────────────────────────
BOT_TOKEN=123456789:AA...replace_me
# Random string used as Telegram webhook secret_token (anti-spoof)
TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_string
# Public URL where Vercel deploys (used by scripts/setWebhook.ts)
PUBLIC_BASE_URL=https://your-project.vercel.app

# ─── Firebase Admin ───────────────────────────────────────
# Base64 of the entire service-account JSON file content.
# PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("FIREBASE_SERVICE_ACCOUNT_B64.json"))
FIREBASE_SERVICE_ACCOUNT_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# ─── Lead Magnet ──────────────────────────────────────────
LEAD_MAGNET_URL=https://example.com/free-guide.pdf
LEAD_MAGNET_TEXT=Here is your free guide as promised. Enjoy!

# ─── Premium offer ────────────────────────────────────────
PREMIUM_PRICE_USDT=15
PREMIUM_TITLE=AI Pinterest Pro Pack
PREMIUM_DELIVERY_URL=https://example.com/premium-archive.zip

# ─── Crypto Pay (https://help.crypt.bot/crypto-pay-api) ───
CRYPTO_PAY_TOKEN=12345:AAA...your_app_token
# mainnet | testnet
CRYPTO_PAY_NETWORK=mainnet

# ─── Boosty ───────────────────────────────────────────────
# Shared secret you configure in Boosty -> Webhooks
BOOSTY_WEBHOOK_SECRET=any_long_string
# Your Boosty page slug, used to deep-link users
BOOSTY_PAGE_URL=https://boosty.to/your-page/single-payment/donation/12345

# ─── Cron protection ──────────────────────────────────────
# Vercel automatically sends Authorization: Bearer <CRON_SECRET> for crons
CRON_SECRET=generate_another_long_random_string

# ─── Pinterest Auto-Poster ─────────────────────────────────
# Browser session storage (cookies from your Pinterest account)
# Generate with: playwright auth-cli --auth-cache auth_json.json https://www.pinterest.com
AUTH_STATE_PATH=./auth_json.json

# Persistent browser profile directory (stores cookies, cache, etc.)
USER_DATA_DIR=./browser-profile

# NaProxy proxy (optional but recommended)
# Format: http://host:port or socks5://host:port
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Browser viewport
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768

# Headless mode (true for GitHub Actions, false for local debugging)
HEADLESS=true

# Firestore collection for content plan
CONTENT_PLAN_COLLECTION=content_plan

# Temp directory for downloaded media files (default: ./temp)
TEMP_DIR=./temp

# Screenshots directory on errors (default: ./screenshots)
SCREENSHOTS_DIR=./screenshots

# Interval between posting cycles in seconds when running in loop (default: 300)
POST_INTERVAL_SEC=300
